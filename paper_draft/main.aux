\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Self-detection accuracy: models choose between the correct answer and their own hallucinated answer (order randomized). All models perform far below chance (50\%) on hallucinated questions while achieving high accuracy on controls. The gap ranges from 56 to 81 percentage points.\relax }}{8}{table.caption.7}\protected@file@percent }
\newlabel{tab:self_detection}{{4}{8}{Self-detection accuracy: models choose between the correct answer and their own hallucinated answer (order randomized). All models perform far below chance (50\%) on hallucinated questions while achieving high accuracy on controls. The gap ranges from 56 to 81 percentage points.\relax }{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Self-detection accuracy on hallucinated versus control questions. On hallucinated questions, all models perform below 50\% chance (dashed line), indicating systematic bias toward their own incorrect answer. Control accuracy is dramatically higher.\relax }}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:self_detection}{{3}{8}{Self-detection accuracy on hallucinated versus control questions. On hallucinated questions, all models perform below 50\% chance (dashed line), indicating systematic bias toward their own incorrect answer. Control accuracy is dramatically higher.\relax }{figure.caption.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Pairwise Jaccard similarity of hallucination sets. All values are 3--6$\times $ above random baseline (permutation test, 1,000 iterations, all $p < 0.001$). Higher values indicate greater overlap in which specific questions cause hallucinations.\relax }}{9}{table.caption.9}\protected@file@percent }
\newlabel{tab:jaccard}{{5}{9}{Pairwise Jaccard similarity of hallucination sets. All values are 3--6$\times $ above random baseline (permutation test, 1,000 iterations, all $p < 0.001$). Higher values indicate greater overlap in which specific questions cause hallucinations.\relax }{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Temporal prediction of hallucinations. $P(\text  {new wrong} \mid \text  {old wrong})$ is the probability that the newer model hallucinates given that the older model hallucinated on the same question. Both correlations are highly significant ($p < 0.0001$).\relax }}{9}{table.caption.10}\protected@file@percent }
\newlabel{tab:temporal}{{6}{9}{Temporal prediction of hallucinations. $P(\text {new wrong} \mid \text {old wrong})$ is the probability that the newer model hallucinates given that the older model hallucinated on the same question. Both correlations are highly significant ($p < 0.0001$).\relax }{table.caption.10}{}}
