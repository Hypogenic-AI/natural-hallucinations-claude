\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Hallucination persistence rates by model across five question rephrasings. Most hallucinations survive rephrasing, with an overall mean of 76.1\%.\relax }}{7}{figure.caption.6}\protected@file@percent }
